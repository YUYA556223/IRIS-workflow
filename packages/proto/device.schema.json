{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iris.memorylab.jp/schemas/device.schema.json",
  "title": "IRIS Device",
  "description": "デバイスレジストリエントリと MQTT メッセージスキーマ。詳細は docs/concept/07-devices-and-widgets.md を参照",
  "type": "object",
  "required": ["id", "kind", "name", "capabilities"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "kind": { "type": "string", "enum": ["ios", "windows", "iot-mqtt", "browser"] },
    "name": { "type": "string" },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "enum": ["widget", "notification", "voice-in", "sdui", "mqtt-pub", "mqtt-sub"] }
    },
    "auth": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["tailscale-tag", "shared-secret", "tls-cert"] }
      }
    }
  }
}
